{
  "name": "react-unsplash",
  "version": "1.0.0",
  "description": "A highly customizable React component library for integrating Unsplash photo picker into your projects. Supports shadcn/Tailwind, compound components, render props, and full TypeScript.",
  "keywords": [
    "react",
    "unsplash",
    "photo",
    "image",
    "picker",
    "gallery",
    "shadcn",
    "tailwind",
    "typescript",
    "component",
    "library",
    "masonry"
  ],
  "author": "thucne",
  "license": "MIT",
  "homepage": "https://github.com/thucne/react-unsplash#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/thucne/react-unsplash.git"
  },
  "bugs": {
    "url": "https://github.com/thucne/react-unsplash/issues"
  },
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/react-unsplash.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:lib": "tsup",
    "build:lib:watch": "tsup --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm build:lib && pnpm type-check"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "blurhash": "^2.0.5"
  },
  "devDependencies": {
    "@emotion/cache": "^11.11.0",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.20",
    "@mui/material": "^5.15.20",
    "@mui/material-nextjs": "^5.15.11",
    "@types/lodash": "^4.17.5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.4",
    "lodash": "^4.17.21",
    "next": "14.2.4",
    "postcss": "^8",
    "react": "^18",
    "react-dom": "^18",
    "swr": "^2.2.5",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.5.1",
    "type-fest": "^4.23.0",
    "typescript": "^5"
  }
}